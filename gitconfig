[core]
  editor = nvr --remote-wait-silent
	excludesfile = ~/.gitignore_global
[diff]
  tool = nvr
[difftool "nvr"]
  cmd = nvr -s -d $LOCAL $REMOTE
[merge]
  tool = nvr
[mergetool "nvr"]
  cmd = nvr -s -d $LOCAL $BASE $REMOTE $MERGED -c 'wincmd J | wincmd ='
[url "git@github.com:"]
  insteadOf = https://github.com/
